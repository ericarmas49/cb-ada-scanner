<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Accessibility Report</title>
  <style>{{ css }}</style>
</head>
<body>
  <header class="header">
    <div>
      <h1>Accessibility Report</h1>
      <p class="meta">Generated {{ generated_at }}</p>
    </div>
    <div class="score">
      <div class="score-label">Score</div>
      <div class="score-value">{{ report.summary.score }}</div>
    </div>
  </header>

  <section class="section">
    <h2>Executive Summary</h2>
    <div class="summary-grid">
      <div class="summary-item">
        <div class="label">Critical</div>
        <div class="value critical">{{ report.summary.totals.critical }}</div>
      </div>
      <div class="summary-item">
        <div class="label">Serious</div>
        <div class="value serious">{{ report.summary.totals.serious }}</div>
      </div>
      <div class="summary-item">
        <div class="label">Moderate</div>
        <div class="value moderate">{{ report.summary.totals.moderate }}</div>
      </div>
      <div class="summary-item">
        <div class="label">Minor</div>
        <div class="value minor">{{ report.summary.totals.minor }}</div>
      </div>
    </div>
    <div class="notes">
      {% for note in report.summary.notes %}
        <p>{{ note }}</p>
      {% endfor %}
    </div>
  </section>

  <section class="section">
    <h2>What Was Tested</h2>
    <ul class="meta-list">
      <li><strong>Input URL:</strong> {{ report.scan.inputUrl }}</li>
      <li><strong>Final URL:</strong> {{ report.scan.finalUrl }}</li>
      <li><strong>Title:</strong> {{ report.page.title }}</li>
      <li><strong>Scan Started:</strong> {{ report.scan.startedAt }}</li>
      <li><strong>Scan Finished:</strong> {{ report.scan.finishedAt }}</li>
    </ul>
  </section>

  <section class="section">
    <h2>Top Issues</h2>
    {% if grouped %}
      {% for rule_id, items in grouped.items() %}
        <div class="finding-group">
          <h3>{{ items[0].title }}</h3>
          <p class="meta">Rule ID: {{ rule_id }} | Occurrences: {{ items | sum(attribute='occurrences') }}</p>
          <p>{{ items[0].why }}</p>
          {% if items[0].remediation or items[0].fix %}
          <p><strong>Reference (informational):</strong> {{ items[0].remediation or items[0].fix }}</p>
          {% endif %}

          {% for item in items %}
            <div class="finding-item">
              <div class="finding-meta">
                <span class="pill {{ item.severity }}">{{ item.severity }}</span>
                <span class="pill">Confidence: {{ item.confidence }}</span>
                {% if item.manual_review_required %}
                  <span class="pill warn">Manual review</span>
                {% endif %}
              </div>
              {% if item.evidence.screenshot %}
                <img class="screenshot" src="{{ item.evidence.screenshot }}" alt="Evidence screenshot" />
              {% endif %}
              <div class="selector">{{ item.selector }}</div>
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    {% else %}
      <p>No issues detected by automated checks.</p>
    {% endif %}
  </section>

  <section class="section">
    <h2>Manual Review Needed</h2>
    {% if manual_review %}
      {% for item in manual_review %}
        <div class="finding-item">
          <div class="finding-meta">
            <span class="pill {{ item.severity }}">{{ item.severity }}</span>
            <span class="pill">Confidence: {{ item.confidence }}</span>
          </div>
          <div><strong>{{ item.title }}</strong></div>
          <div class="selector">{{ item.selector }}</div>
          <p>{{ item.why }}</p>
        </div>
      {% endfor %}
    {% else %}
      <p>No manual review items were flagged.</p>
    {% endif %}
  </section>

  <footer class="footer">
    <p>Report generated by Single-URL WCAG 2.2 AA Scanner.</p>
  </footer>
</body>
</html>
